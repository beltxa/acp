# ACP relay demo environment variables.
# Copy to demo/relay/.env and adjust only if needed.

ACP_RELAY_HOST=0.0.0.0
ACP_RELAY_PORT=8080
ACP_DISCOVERY_SCHEME=http
ACP_ALLOW_INSECURE_HTTP=true
ACP_ALLOW_INSECURE_TLS=false
ACP_CA_FILE=
ACP_RELAY_TIMEOUT_SECONDS=5
ACP_RELAY_STORE_AND_FORWARD=true
ACP_RELAY_RETRY_INTERVAL_SECONDS=2
ACP_RELAY_MAX_RETRY_ATTEMPTS=3
ACP_RELAY_RETRY_BACKOFF_SECONDS=2

# Not required for this demo flow:
ACP_AMQP_BROKER_URL=
